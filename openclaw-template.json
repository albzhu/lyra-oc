  "bindings": [
    {
      "comment": "PARKED until Mac mini migration. To enable: install `brew install steipete/tap/imsg` (arm64 native on the mini), grant Full Disk Access + Automation->Messages to the gateway, decide Apple ID (dedicated ID on mini => current allowFrom +18186674686 works), set channels.imessage.enabled=true, then make sync && make restart.",
      "agentId": "main",
      "match": {
        "channel": "imessage"
      }
    }
  ],
  "channels": {
    "imessage": {
      "name": "iMessage (PARKED \u2014 enable on Mac mini)",
      "enabled": false,
      "service": "auto",
      "sendTransport": "applescript",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "+18186674686"
      ],
      "groupPolicy": "disabled",
      "actions": {
        "reply": true
      },
      "markdown": {
        "tables": "bullets"
      },
      "dmHistoryLimit": 20
