# OpenClaw Environment File
# Copy this file to .env and configure your security settings and tokens.

# Gateway Access Security Token
GATEWAY_AUTH_TOKEN=  ### OPENCLAW GATEWAY TOKEN
NODE_ENV=production
TZ=America/Los_Angeles ### CHANGE THIS TO YOUR LOCALE

# Workspace root — the single knob that relocates all agent workspaces.
# Read by the Makefile and openclaw-template.json (${OPENCLAW_WORKSPACE_ROOT}).
# Leave unset to default to ~/.openclaw (where this repo is deployed).
# OPENCLAW_WORKSPACE_ROOT=${HOME}/.openclaw

# --- Channels ---
# Discord bot token (channels.discord is enabled in the template — required).
DISCORD_BOT_TOKEN=

# API Keys (Provide keys for your configured models)
# OPENAI_API_KEY=
# CLAUDE_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# --- Skill / tool service keys (optional — only if the feature is enabled) ---
# Gemini-backed web search (tools.web.search / plugins.google.webSearch)
# GOOGLE_WEB_SEARCH_API_KEY=
# goplaces skill
# GOPLACES_API_KEY=
