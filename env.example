# OpenClaw Environment File
# Copy this file to .env and fill in your values.
# The setup wizard (install.command) does this for you automatically.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Gateway security token — auto-generated by the setup wizard.
# To rotate: run `make roll`
GATEWAY_AUTH_TOKEN=

# OpenRouter API key — required. All agents route through OpenRouter.
# Get a free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Timezone for the gateway service
TZ=America/Los_Angeles

# ── OPTIONAL: Direct provider keys ────────────────────────────────────────────
# These improve reliability for your chosen primary provider but are not required
# since all models are also accessible via OpenRouter above.

# Anthropic Claude (recommended if you chose Claude as your primary AI)
# Get a key at: https://console.anthropic.com/
# CLAUDE_API_KEY=

# Google Gemini (recommended if you chose Gemini as your primary AI)
# Get a key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# OpenAI (recommended if you chose GPT as your primary AI)
# Get a key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ── OPTIONAL: Channels ────────────────────────────────────────────────────────
# Not required for initial setup. LYRA can guide you through adding these
# after your system is running.

# Discord bot token — ask LYRA "how do I connect Discord?" to get started
# DISCORD_BOT_TOKEN=

# ── OPTIONAL: Search & skills ─────────────────────────────────────────────────
# GOOGLE_WEB_SEARCH_API_KEY=
# GOPLACES_API_KEY=

# ── ADVANCED ──────────────────────────────────────────────────────────────────
# Workspace root override. Leave unset to use the default (~/.openclaw).
# Only change this if you cloned the repo somewhere other than ~/.openclaw.
# OPENCLAW_WORKSPACE_ROOT=${HOME}/.openclaw

NODE_ENV=production
